# Copy this file to .env and fill in real values.
# .env is git-ignored — never commit it.
#
# REQUIRED vars must be set before running docker compose.
# OPTIONAL vars can be left empty; the pipeline runs fully offline without them.

# ── REQUIRED ──────────────────────────────────────────────────────────────────

# PostgreSQL password — choose a strong password (min 16 chars recommended)
POSTGRES_PASSWORD=

# JupyterLab access token — choose a strong token
JUPYTER_TOKEN=

# ── OPTIONAL: database name / user (defaults shown) ──────────────────────────

POSTGRES_USER=psalms
POSTGRES_DB=psalms

# ── OPTIONAL: LLM provider for Stage 5 suggestions ───────────────────────────
# Set LLM_PROVIDER to one of: none | anthropic | openai | gemini | openrouter | ollama
# Leave as "none" to run the full pipeline without any LLM calls.

LLM_PROVIDER=none
LLM_MODEL=
LLM_API_KEY=

# Provider-specific keys (only needed when LLM_PROVIDER matches)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=

# ── OPTIONAL: Ollama (local LLM) ─────────────────────────────────────────────
# Only needed when LLM_PROVIDER=ollama
OLLAMA_HOST=

# ── OPTIONAL: ESV Bible API ───────────────────────────────────────────────────
# Only needed if adding ESV as a translation source (licensed — not included by default)
ESV_API_KEY=
